{
  "name": "Bubble Track API Dev Container",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "containerUser": "vibecoder",
  "remoteUser": "vibecoder",
  "containerEnv": {
    "GOPATH": "/home/vibecoder/go"
  },
  "postCreateCommand": "sudo chown -R vibecoder /go /home/vibecoder /workspaces /workspace 2>/dev/null; (command -v opencode >/dev/null 2>&1 || curl -fsSL https://opencode.ai/install | bash); test -f go.mod && go mod download || true",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "go.toolsManagement.checkForUpdates": "off",
        "go.useLanguageServer": true,
        "go.gopath": "/home/vibecoder/go",
        "go.goroot": "/usr/local/go",
        "go.alternateTools": {
          "gopls": "/usr/local/bin/gopls",
          "dlv": "/usr/local/bin/dlv",
          "staticcheck": "/usr/local/bin/staticcheck"
        }
      },
      "extensions": [
        "golang.go",
        "github.copilot-chat",
        "github.copilot",
        "dbcode.dbcode"
      ]
    }
  }
}