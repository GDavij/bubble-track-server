{
  "name": "Bubble Track API Dev Container",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "vibecoder",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "go.toolsManagement.checkForUpdates": "local",
        "go.useLanguageServer": true,
        "go.gopath": "/home/vibecoder/go"
      },
      "extensions": [
        "golang.go",
        "github.copilot-chat",
        "github.copilot",
        "dbcode.dbcode"
      ]
    }
  },
  "postCreateCommand": "go mod download"
}