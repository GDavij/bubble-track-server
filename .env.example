# Bubble Track Server Configuration
# Copy this file to .env and fill in your values

# Server
SERVER_PORT=8080
APP_ENV=development

# PostgreSQL
POSTGRES_HOST=postgres.database
POSTGRES_PORT=5432
POSTGRES_USER=bubble_tracker_admin
POSTGRES_PASSWORD=your-password-here
POSTGRES_DB=bubble_tracker
POSTGRES_SSLMODE=disable

# Qdrant (Vector Database)
QDRANT_HOST=qdrant.database
QDRANT_PORT=6334
QDRANT_COLLECTION=bubble_tracker
QDRANT_API_KEY=
QDRANT_USE_TLS=false

# Redis
REDIS_HOST=redis-stack.stack
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# Gemini AI
GEMINI_API_KEY=
GENAI_MODEL=gemini-2.5-flash
GENAI_BACKEND=gemini

# Ollama (set USE_OLLAMA=true to use instead of Gemini)
USE_OLLAMA=true
OLLAMA_HOST=ollama.ai-services
OLLAMA_PORT=11434
OLLAMA_MODEL=gemma4:e4b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text