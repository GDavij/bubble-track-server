# Bubble Track Server Configuration
# Copy this file to .env and fill in your values

# Server
SERVER_PORT=8080
APP_ENV=development

# PostgreSQL
POSTGRES_HOST=postgres.database
POSTGRES_PORT=5432
POSTGRES_USER=bubble_tracker_admin
POSTGRES_PASSWORD=your-password-here
POSTGRES_DB=bubble_tracker
POSTGRES_SSLMODE=disable

# Qdrant (Vector Database)
QDRANT_HOST=qdrant.database
QDRANT_PORT=6334
QDRANT_COLLECTION=bubble_tracker
QDRANT_API_KEY=
QDRANT_USE_TLS=false

# Redis
REDIS_HOST=redis-stack.stack
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# Gemini AI / Vertex AI
# For Gemini AI Studio: set GEMINI_API_KEY, GENAI_BACKEND=gemini
# For Vertex AI: set GEMINI_API_KEY to your Vertex AI credentials, GENAI_BACKEND=vertex
#   Also set GOOGLE_CLOUD_PROJECT and GOOGLE_CLOUD_LOCATION for Vertex AI
GEMINI_API_KEY=
GENAI_MODEL=gemini-2.5-flash
GENAI_BACKEND=gemini          # "gemini" for AI Studio, "vertex" for Vertex AI
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Ollama (set USE_OLLAMA=true to use Ollama instead of Gemini)
#USE_OLLAMA=true
#OLLAMA_HOST=ollama.ai-services
#OLLAMA_PORT=11434
#OLLAMA_MODEL=gemma4:e4b
#OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# LM Studio (for local embeddings via OpenAI-compatible API)
# Set USE_LM_STUDIO=true to use LM Studio for embeddings (e.g. nomic-embed-text)
# LM Studio must be running with its OpenAI-compatible server enabled
#USE_LM_STUDIO=true
#LM_STUDIO_HOST=localhost
#LM_STUDIO_PORT=1234
#LM_STUDIO_EMBEDDING_MODEL=nomic-embed-text-v1.5@q8_0